  <data key="d6"></data>
</node>
<node id="ABC微课堂">
  <data key="d0">ABC微课堂</data>
  <data key="d1">organization</data>
  <data key="d2">ABC微课堂为学习资源平台，文本以其作为获取更多学习资料的渠道。</data>
  <data key="d3">chunk-e9487ce3cb6117273486084a0e8765b5</data>
