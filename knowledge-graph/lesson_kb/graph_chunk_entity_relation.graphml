  <data key="d5">1775721841</data>
  <data key="d6"></data>
</node>
<node id="商用简便记法">
  <data key="d0">商用简便记法</data>
  <data key="d1">method</data>
  <data key="d2">商用简便记法是用于表示除法商的简写或近似表示方式，题目10将9÷11用简便记法表示为约0.82。</data>
  <data key="d3">chunk-b09dcccca5597480c5fa21b39244a059</data>
  <data key="d4">专题02：小数乘除法（期中知识清单）（沪教版）（教师版）.docx</data>
  <data key="d5">1775719584</data>
  <data key="d6"></data>
</node>
<node id="选项B">
  <data key="d0">选项B</data>
  <data key="d1">content</data>
  <data key="d2">题目一中图示将单位分成100个小正方形，涂了20个表示0.2，符合表示0.2的意思。&lt;SEP&gt;题目中的选项B，用于与正方体展开图结构类别对应判断。</data>
  <data key="d3">chunk-ab3980b34a88bc285f121c3d3ee984b9&lt;SEP&gt;chunk-ef37bd7225840359eb8ce1fb7b40d412</data>
