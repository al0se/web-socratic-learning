  <data key="d6"></data>
</node>
<node id="逸夫小学">
  <data key="d0">逸夫小学</data>
  <data key="d1">organization</data>
  <data key="d2">逸夫小学是教材中盈亏问题的实例主体，示例中该校安排春游订车并计算出订车数为17辆、参加人数为1120人。</data>
  <data key="d3">chunk-1a1cbe94a2af92f629f04847b2d9adef</data>
  <data key="d4">五年级 第二学期 知识点  （11页）.docx</data>
